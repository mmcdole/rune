---
// Focused feature demos below the fact grid: real client footage
// (website/demo/render.sh), one video per feature, wrapped in the same
// terminal chrome as the hero. Videos play only while in view.
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';

const demos = [
  {
    id: 'pickers',
    title: 'Pickers for everything',
    body:
      'Saved worlds, command history, your aliases, and every slash ' +
      'command sit one keypress away, fuzzy-filtered as you type. ' +
      'Scripts can open the same picker with their own items.',
    keys: [
      ['/connect', 'worlds'],
      ['Ctrl+R', 'history'],
      ['Ctrl+T', 'aliases'],
    ],
    term: 'rune',
    aria:
      'Recording: the world picker connects to a MUD, Ctrl+R filters ' +
      'command history, and Ctrl+T browses aliases',
  },
  {
    id: 'verbatim',
    title: 'Multiline, sent verbatim',
    body:
      'Paste multiline text - or press Ctrl+Enter - and the input grows ' +
      'into a composer with numbered lines. Enter sends the draft ' +
      'exactly as written: no alias expansion, no splitting, no lost ' +
      'blank lines. Boards and mail editors just work.',
    keys: [
      ['Ctrl+Enter', 'compose'],
      ['Enter', 'send as written'],
    ],
    term: 'rune — mud.arctic.org:2700',
    aria:
      'Recording: Ctrl+Enter grows the input line into a multiline ' +
      'composer and Enter sends each line to the server as written',
  },
  {
    id: 'editor',
    title: 'Your editor, mid-session',
    body:
      'When a draft deserves better than a one-line box, Ctrl+E opens ' +
      'it in Vim, Emacs, or whatever $EDITOR points at. Save and quit, ' +
      'and the whole letter lands back in the composer, ready to send.',
    keys: [['Ctrl+E', 'edit in $EDITOR']],
    term: 'rune — mud.arctic.org:2700',
    aria:
      'Recording: Ctrl+E opens the input in vim, a multi-line letter ' +
      'is written and saved, and it returns to the composer to send',
  },
  {
    id: 'tab',
    title: 'Tab completion that learns',
    body:
      'Words the server has used complete after a single appearance - ' +
      'player names included. Keep pressing Tab and the candidates ' +
      'cycle on the status line; Shift+Tab goes back.',
    keys: [
      ['Tab', 'complete / cycle'],
      ['Shift+Tab', 'back'],
    ],
    term: 'rune — mud.arctic.org:2700',
    aria:
      'Recording: Tab completes a name learned from server output and ' +
      'repeated presses cycle the candidates on the status line',
  },
];
---

<section class="fd">
  {
    demos.map((d, i) => (
      <div class={i % 2 ? 'fd-row flip' : 'fd-row'}>
        <div class="fd-copy">
          <h2>{d.title}</h2>
          <p>{d.body}</p>
          <p class="fd-keys">
            {d.keys.map(([key, label]) => (
              <span class="fd-pair">
                <span class="key">{key}</span> {label}
              </span>
            ))}
          </p>
        </div>
        <div class="fterm">
          <div class="fterm-bar">
            <span class="fdot" /><span class="fdot" /><span class="fdot" />
            <span class="ftitle">{d.term}</span>
          </div>
          <video
            src={`${base}demos/${d.id}.mp4`}
            poster={`${base}demos/${d.id}-poster.jpg`}
            muted loop playsinline preload="metadata"
            aria-label={d.aria}
          />
        </div>
      </div>
    ))
  }
</section>

<style>
  .fd { padding: 40px 0 8px; display: grid; gap: 44px; }

  .fd-row {
    display: grid;
    grid-template-columns: minmax(260px, 4fr) minmax(340px, 6fr);
    gap: 40px;
    align-items: center;
  }
  /* Flipped rows swap the columns too, so the terminal keeps the wide
     column instead of shrinking into the copy column. */
  .fd-row.flip { grid-template-columns: minmax(340px, 6fr) minmax(260px, 4fr); }
  .fd-row.flip .fd-copy { order: 2; }
  @media (max-width: 880px) {
    .fd-row, .fd-row.flip { grid-template-columns: 1fr; gap: 18px; }
    .fd-row.flip .fd-copy { order: 0; }
  }

  .fd-copy h2 {
    font-family: var(--mono);
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }
  .fd-copy p { color: var(--muted); font-size: 15.5px; line-height: 1.6; margin: 0 0 12px; max-width: 44ch; }
  .fd-keys { display: flex; flex-wrap: wrap; gap: 8px 18px; align-items: center; }
  .fd-pair { display: inline-flex; align-items: center; gap: 7px; white-space: nowrap; color: var(--muted); font-size: 14px; }
  .key {
    font-family: var(--mono); font-size: 12px;
    color: var(--fg);
    background: var(--panel);
    border: 1px solid var(--panel-edge);
    border-bottom-width: 2px;
    border-radius: 5px;
    padding: 2px 7px;
    white-space: nowrap;
  }

  .fterm {
    background: #16161e;
    border: 1px solid var(--panel-edge);
    border-radius: 10px;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.4);
    overflow: hidden;
  }
  .fterm-bar {
    display: flex; align-items: center; gap: 7px;
    padding: 8px 12px;
    background: var(--panel);
    border-bottom: 1px solid var(--panel-edge);
  }
  .fdot { width: 10px; height: 10px; border-radius: 50%; background: #3b3f58; }
  .ftitle { margin-left: 8px; color: var(--muted); font-size: 11.5px; font-family: var(--mono); }
  .fterm video { display: block; width: 100%; height: auto; }
</style>

<script>
  // Play each demo only while it is on screen; honor reduced motion by
  // leaving the poster frame until the visitor interacts.
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const videos = document.querySelectorAll<HTMLVideoElement>('.fd video');

  if (!reduced) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          const v = e.target as HTMLVideoElement;
          if (e.isIntersecting) v.play().catch(() => {});
          else v.pause();
        }
      },
      { threshold: 0.3 },
    );
    videos.forEach((v) => io.observe(v));
  }
</script>
