---
// The landing page body: an animated hero terminal that simulates a real
// session (welcome, connect, rooms, pickers), plus a compact fact grid
// and per-feature mini demos.
// All styling is scoped; Starlight's splash template provides the frame.
import FeatureDemos from './FeatureDemos.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<div class="landing not-content">
  <header class="hero-grid">
    <div>
      <p class="brand">ᚱune</p>
      <h1>Script the <span class="accent">client</span>, not just the game.</h1>
      <p class="sub">
        A fast, modern MUD client with careful terminal ergonomics and a Lua
        API that goes all the way down.
      </p>
      <div class="cta-row">
        <a class="btn primary" href={`${base}getting-started/installation/`}>Get started</a>
        <a class="btn" href="https://github.com/mmcdole/rune/releases">Download</a>
      </div>
      <p class="install"><span class="dollar">$</span> rune mud.example.com 4000</p>
      <p class="platforms">LINUX · MACOS · WINDOWS · SINGLE BINARY, NO RUNTIME</p>
    </div>

    <div>
      <div class="term demo" id="demo">
        <div class="term-bar">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="term-title">rune</span>
          <button class="replay" id="demo-replay" type="button" title="Replay demo">↻ replay</button>
        </div>
        <!-- Real client footage (see website/demo/): connecting to a MUD,
             walking between rooms, tab completion, history search, and the
             chat-console pane. Regenerate with website/demo/render.sh. -->
        <video
          id="demo-video"
          src={`${base}demos/hero.mp4`}
          poster={`${base}demos/hero-poster.jpg`}
          autoplay muted loop playsinline preload="metadata"
          aria-label="Recording of a Rune session: connecting to a MUD, walking between rooms, tab completion, searching history, and toggling a chat console pane"
        ></video>
      </div>
    </div>
  </header>

  <section>
    <div class="grid">
      <div class="card">
        <h3>Everything is Lua</h3>
        <p>Core client functionality is Lua: input handling, the UI, the keymap. All of it can be overridden.</p>
      </div>
      <div class="card">
        <h3>GMCP · MCCP2 · TLS</h3>
        <p>Vitals and room data arrive as Lua events. Compression and encryption are on by default.</p>
      </div>
      <div class="card">
        <h3>Panes · Bars · Pickers</h3>
        <p>Dock chat panes, render live status bars, open fuzzy-filtered pickers. Every UI component is scriptable.</p>
      </div>
      <div class="card">
        <h3>Feels like your shell</h3>
        <p>Prefix-matching history, tab completion that learns names from server output, and <code>Ctrl+E</code> to edit the input line in <code>$EDITOR</code>.</p>
      </div>
    </div>
  </section>

  <FeatureDemos />
</div>

<style>
  .landing {
    max-width: 1080px;
    margin: 0 auto;
    --blue: #7aa2f7;
    --ground: #14151f;
    --panel: #1b1d2b;
    --panel-edge: #2a2d42;
    --fg: #c9cede;
    --muted: #7a8099;
    --amber: #e0af68;
    --cyan: #7dcfff;
    --green: #9ece6a;
    --red: #f7768e;
    --magenta: #bb9af7;
    --mono: var(--sl-font-mono);
    font-size: 17px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(300px, 5fr) minmax(340px, 6fr);
    gap: 48px;
    align-items: center;
  }
  @media (max-width: 880px) { .hero-grid { grid-template-columns: 1fr; } }

  /* The wordmark leads the hero, full size. */
  .brand {
    font-family: var(--mono);
    font-size: clamp(44px, 5.4vw, 60px);
    font-weight: 700;
    color: var(--amber);
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0 0 18px;
  }
  h1 {
    font-family: var(--mono);
    font-size: clamp(30px, 4.2vw, 42px);
    line-height: 1.18;
    font-weight: 700;
    margin: 0 0 16px;
    text-wrap: balance;
    letter-spacing: -0.01em;
  }
  h1 .accent { color: var(--amber); }
  .sub { max-width: 46ch; color: #a9afc4; font-size: 18px; margin: 0 0 28px; }

  .cta-row { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; margin-bottom: 22px; }
  /* A terminal snippet, not a third button: no pill chrome. */
  .install {
    font-family: var(--mono); font-size: 14px;
    color: var(--fg);
    margin: 0 0 12px;
  }
  .install .dollar { color: var(--muted); user-select: none; }
  .btn {
    font-family: var(--mono); font-size: 14px;
    padding: 10px 18px; border-radius: 6px;
    border: 1px solid var(--panel-edge);
    color: var(--fg); background: transparent;
    text-decoration: none;
  }
  .btn.primary { background: var(--amber); border-color: var(--amber); color: #14151f; font-weight: 700; }
  .btn.primary:hover { filter: brightness(1.08); }
  .platforms { font-family: var(--mono); font-size: 12.5px; color: var(--muted); letter-spacing: 0.04em; }

  .term {
    background: #16161e;
    border: 1px solid var(--panel-edge);
    border-radius: 10px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
    overflow: hidden;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.5;
    color: var(--fg);
    position: relative;
  }
  .term-bar {
    display: flex; align-items: center; gap: 7px;
    padding: 10px 14px;
    background: var(--panel);
    border-bottom: 1px solid var(--panel-edge);
  }
  .dot { width: 11px; height: 11px; border-radius: 50%; background: #3b3f58; }
  .term-title { margin-left: 8px; color: var(--muted); font-size: 12px; }
  .replay {
    margin-left: auto;
    background: none; border: none; cursor: pointer;
    font-family: var(--mono); font-size: 11px;
    color: var(--muted); padding: 2px 6px;
  }
  .replay:hover { color: var(--fg); }
  .term video { display: block; width: 100%; height: auto; }

  section { padding: 56px 0 8px; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    grid-auto-rows: 1fr;
    gap: 14px;
  }
  .card {
    background: var(--panel);
    border: 1px solid var(--panel-edge);
    border-radius: 8px;
    padding: 18px 20px;
  }
  .card h3 { font-family: var(--mono); font-size: 15px; font-weight: 700; margin: 0 0 6px; color: var(--fg); }
  .card p { margin: 0; color: var(--muted); font-size: 15px; line-height: 1.55; }
  .card code { font-size: 13px; color: var(--cyan); background: none; }
</style>

<style is:global>
  /* The landing provides its own hero: hide the auto-rendered page
     title and the empty content panel that wraps it. */
  .content-panel:has(> .sl-container > h1#_top) { display: none; }
  h1#_top { display: none; }
</style>

<script>
  // The hero is real client footage (website/demo/render.sh). Autoplay
  // is muted+looped; reduced-motion visitors get the poster frame and
  // can start it themselves via the replay button.
  const video = document.getElementById('demo-video') as HTMLVideoElement;
  const replay = document.getElementById('demo-replay')!;

  if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
    video.autoplay = false;
    video.pause();
  }
  replay.addEventListener('click', () => {
    video.currentTime = 0;
    video.play();
  });
</script>
